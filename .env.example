# CONFIGURACIÓN DE BASE DE DATOS (SUPABASE)
# Reemplaza los valores con los datos reales de tu proyecto en Supabase.
# Nunca subas tu archivo '.env.local' con las claves reales a GitHub.

# URL del proyecto de Supabase (ej: https://abcde12345.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url

# Clave pública anónima de Supabase (anon / public)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_public_key

# Clave de rol de servicio de Supabase (service_role) - Usada para operaciones seguras en el servidor
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key


# CONFIGURACIÓN DE PROCESAMIENTO DE IA (GOOGLE GEMINI)
# Obtén tu clave en Google AI Studio (https://aistudio.google.com)
GEMINI_API_KEY=your_google_gemini_api_key
